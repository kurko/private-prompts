#!/usr/bin/env bash
set -euo pipefail

# Lint text for AI writing anti-patterns, and auto-fix curly quotes.
#
# Usage:
#   lint-prose <file>         # fixes curly quotes in place, lints the rest
#   echo "some text" | lint-prose   # fixed text -> stdout, diagnostics -> stderr
#
# Diagnostics go to stderr so that stdout carries the corrected text in pipe
# mode. Exit code still drives pass/fail: 0 = clean, 1 = violations remain.

file=""
if [ $# -gt 0 ]; then
  # File mode
  if [ ! -f "$1" ]; then
    echo "FAIL: file not found: $1" >&2
    exit 1
  fi
  file="$1"
  input="$(cat "$file")"
else
  # Pipe mode
  if [ -t 0 ]; then
    echo "Usage: lint-prose <file>" >&2
    echo "       echo \"text\" | lint-prose" >&2
    exit 1
  fi
  input="$(cat)"
fi

# Auto-fix curly quotes -> straight quotes. Alex types straight quotes on his
# machine, so curly ones are a tell that the text came from somewhere else.
# The substitution is mechanical and lossless, so fix it rather than making a
# human decide (unlike em dashes, which need a real rewrite).
#
# Single: ' U+2018  ' U+2019  ‚ U+201A  ‛ U+201B
# Double: " U+201C  " U+201D  „ U+201E  ‟ U+201F
#
# Each character gets its own -e expression: bracket expressions containing
# multibyte characters are unreliable in BSD sed on macOS.
fixed="$(printf '%s' "$input" | sed \
  -e "s/‘/'/g" \
  -e "s/’/'/g" \
  -e "s/‚/'/g" \
  -e "s/‛/'/g" \
  -e 's/“/"/g' \
  -e 's/”/"/g' \
  -e 's/„/"/g' \
  -e 's/‟/"/g')"

if [ "$fixed" != "$input" ]; then
  curly_count="$(printf '%s' "$input" \
    | grep -o -e '‘' -e '’' -e '‚' -e '‛' -e '“' -e '”' -e '„' -e '‟' \
    | wc -l | tr -d ' ')" || curly_count="?"
  if [ -n "$file" ]; then
    printf '%s\n' "$fixed" > "$file"
    echo "FIXED: replaced $curly_count curly quote(s) with straight quotes in $file" >&2
  else
    echo "FIXED: replaced $curly_count curly quote(s) with straight quotes" >&2
  fi
fi

# Everything below lints the corrected text.
input="$fixed"

fail=0

# Check for em dashes (U+2014). Literal character, not \x{2014}:
# BSD grep on macOS has no -P (PCRE), and a failing grep made this check
# silently pass forever.
if echo "$input" | grep -n '—' >&2; then
  echo "FAIL: em dashes found. Replace with commas, parentheses, or separate sentences." >&2
  fail=1
fi

# Banned framing phrases: they assert importance or build tension without
# adding information. Name the concrete thing and state it directly.
banned_phrases=(
  "here's the thing"
  "bottom line"
  "the catch:"
  "the kicker:"
  "the gap:"
  "what matters"
  "not flashy"
)

for phrase in "${banned_phrases[@]}"; do
  if echo "$input" | grep -Fin "$phrase" >&2; then
    echo "FAIL: banned framing phrase (\"$phrase\"). State the thing directly." >&2
    fail=1
  fi
done

# In pipe mode, hand the corrected text back on stdout.
if [ -z "$file" ]; then
  printf '%s\n' "$fixed"
fi

if [ "$fail" -eq 1 ]; then
  exit 1
fi

echo "PASS: no em dashes or banned phrases found." >&2
